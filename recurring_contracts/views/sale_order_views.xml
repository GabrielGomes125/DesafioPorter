<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_recurring_contract" model="ir.ui.view">
        <field name="name">sale.order.form.recurring.contract</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="x_recurring_contract_id"
                       readonly="x_recurring_contract_id and state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>
